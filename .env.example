# Limen – Umgebungsvariablen. Kopieren nach .env und Secrets befüllen.
# Ausführliche Erläuterung jeder Variable: .env.example.read

APP_BASE_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# Optional, empfohlen hinter nginx: Shared-Secret, das nginx als Header
#   proxy_set_header X-Proxy-Auth <secret>;
# mitschickt. Ist es gesetzt, vertraut die App X-Real-IP/X-Forwarded-For nur bei
# vorhandenem, passendem Header (verhindert IP-Spoofing/Drossel-Umgehung bei
# Direktzugriff). Erzeugen mit:  openssl rand -hex 16
# TRUSTED_PROXY_SECRET=

# Secrets erzeugen mit:  openssl rand -hex 32
AUTH_SECRET=
ENCRYPTION_KEY=

DATABASE_URL=postgres://sso:CHANGE_ME@localhost:5432/sso
POSTGRES_PASSWORD=CHANGE_ME

ADMIN_USER=admin
ADMIN_PASSWORD=CHANGE_ME

UPLOAD_DIR=./uploads
