# =====================================================================
#  Limen – ausführlich kommentiertes Nachschlagewerk (NICHT als .env nutzen!)
#  Zum Deployen die schlanke Vorlage verwenden:  cp .env.example .env
#  Die hier gesetzten CHANGE_ME-Werte sind ABSICHTLICH ungültig, damit der
#  Dienst nicht versehentlich mit bekannten Secrets startet.
# =====================================================================

# --- Öffentliche Basis-URL / OIDC issuer ---
# Muss exakt der von außen erreichbaren HTTPS-URL entsprechen (hinter nginx).
# In Entwicklung: http://localhost:3000
APP_BASE_URL=http://localhost:3000

# Hinter Reverse-Proxy (nginx) auf true setzen, damit X-Forwarded-* vertraut wird.
AUTH_TRUST_HOST=true

# --- Trusted-Proxy-Shared-Secret (optional, empfohlen hinter nginx) ---
# Schützt die aus Headern abgeleitete Client-IP (IP-Drossel, Audit, Anmeldeverlauf)
# gegen Spoofing bei direktem Zugriff an nginx vorbei. Wenn gesetzt, akzeptiert die App
# X-Real-IP/X-Forwarded-For NUR, wenn die Anfrage zusätzlich den Header
#   X-Proxy-Auth: <dieses-Secret>
# trägt. In nginx entsprechend ergänzen:  proxy_set_header X-Proxy-Auth <secret>;
# Mindestens 16 Zeichen; erzeugen mit:  openssl rand -hex 16
# Leer lassen = altes Verhalten (X-Real-IP wird unverändert vertraut).
# TRUSTED_PROXY_SECRET=CHANGE_ME

# --- iron-session Secret (>= 32 Zeichen) ---
# Erzeugen mit:  openssl rand -hex 32
AUTH_SECRET=CHANGE_ME

# --- Datenbank ---
# Passwort identisch zu POSTGRES_PASSWORD setzen.
DATABASE_URL=postgres://sso:CHANGE_ME@localhost:5432/sso
POSTGRES_PASSWORD=CHANGE_ME

# --- Bootstrap erster SSO-Admin (beim ersten Start) ---
ADMIN_USER=admin
ADMIN_PASSWORD=CHANGE_ME

# --- Avatar-Uploads (Volume) ---
UPLOAD_DIR=./uploads

# --- Verschlüsselung privater Signaturschlüssel + TOTP-Secrets at rest (AES-256-GCM) ---
# Genau 64 Hex-Zeichen (= 32 Byte):  openssl rand -hex 32
# (CHANGE_ME ist kein gültiges 64-Hex → Start schlägt bewusst fehl, bis ersetzt.)
ENCRYPTION_KEY=CHANGE_ME
